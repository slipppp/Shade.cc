function Window:SetVisible(visible)
    self.Root.Visible = visible
end

function Window:Toggle()
    self:SetVisible(not self.Root.Visible)
end

function Window:SetIcon(icon)
    local image = assetId(icon)
    self.LogoImage.Image = image
    self.LogoImage.Visible = image ~= ""
    self.LogoFallback.Visible = image == ""
end

function Window:SelectTabByName(name)
    for _, tab in ipairs(self.Tabs) do
        if tab.Name == name then
            self:SelectTab(tab)
            return tab
        end
    end

    return nil
end

function Window:SelectSidebarButton(button)
    for _, item in ipairs(self.SidebarButtons) do
        local active = item == button
        item.BackgroundColor3 = active and Color3.fromRGB(40, 24, 38) or Color3.fromRGB(10, 12, 15)
        item.TextColor3 = active and TEXT or MUTED
        item.UIStroke.Transparency = active and 0.1 or 1
    end
end

function Window:SidebarSection(title, items)
    local label = new("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        LayoutOrder = self.SidebarOrder,
        Size = UDim2.new(1, 0, 0, 14),
        Text = title,
        TextColor3 = MUTED,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    label.Parent = self.Sidebar
    self.SidebarOrder += 1

    for _, item in ipairs(items or {}) do
        local text = item.Text or item[1] or tostring(item)
        local icon = item.Icon or item[2] or ""
        local selected = item.Selected == true

        local button = new("TextButton", {
            AutoButtonColor = false,
            BackgroundColor3 = selected and Color3.fromRGB(40, 24, 38) or Color3.fromRGB(10, 12, 15),
            BorderSizePixel = 0,
            Font = Enum.Font.GothamBold,
            LayoutOrder = self.SidebarOrder,
            Size = UDim2.new(1, 0, 0, 26),
            Text = icon .. (icon ~= "" and "  " or "") .. text,
            TextColor3 = selected and TEXT or MUTED,
            TextSize = 12
        }, {
            corner(4),
            stroke(self.Accent, 1, selected and 0.1 or 1)
        })
        button.Parent = self.Sidebar
        table.insert(self.SidebarButtons, button)
        self.SidebarOrder += 1

        button.MouseButton1Click:Connect(function()
            self:SelectSidebarButton(button)

            if item.Tab then
                self:SelectTabByName(item.Tab)
            end

            if item.Callback then
                task.spawn(item.Callback, self, button)
            end
        end)
    end
end

function Window:Tab(name, options)
    options = options or {}

    local tabButton = new("TextButton", {
        AutoButtonColor = false,
        BackgroundColor3 = Color3.fromRGB(16, 17, 21),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBold,
        LayoutOrder = self.TabOrder,
        Size = UDim2.fromOffset(math.max(58, #name * 8 + 18), 27),
        Text = name,
        TextColor3 = MUTED,
        TextSize = 12
    }, {
        corner(4),
        stroke(self.Accent, 1, 1)
    })
    tabButton.Parent = self.TabBar
    self.TabOrder += 1

    local page = new("ScrollingFrame", {
        Name = name,
        Active = true,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        CanvasSize = UDim2.fromOffset(0, 0),
        ScrollBarImageColor3 = self.Accent,
        ScrollBarThickness = 2,
        Size = UDim2.fromScale(1, 1),
        Visible = false
    }, {
        new("UIListLayout", {
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder
        })
    })
    page.Parent = self.Content

    page.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.fromOffset(0, page.UIListLayout.AbsoluteContentSize.Y + 8)
    end)

    local tab = setmetatable({
        Window = self,
        Name = name,
        Button = tabButton,
        Page = page,
        Order = 1
    }, Tab)

    table.insert(self.Tabs, tab)

    tabButton.MouseButton1Click:Connect(function()
        self:SelectTab(tab)
    end)

    if options.Selected or not self.ActiveTab then
        self:SelectTab(tab)
    end

    return tab
end

function Window:SelectTab(tab)
    self.ActiveTab = tab

    for _, item in ipairs(self.Tabs) do
        local active = item == tab
        item.Page.Visible = active
        item.Button.BackgroundTransparency = active and 0 or 1
        item.Button.TextColor3 = active and self.Accent or MUTED
        item.Button.UIStroke.Transparency = active and 0.15 or 1
    end
end

function Tab:_row(labelText)
    local row = new("Frame", {
        BackgroundColor3 = Color3.fromRGB(12, 13, 16),
        BorderSizePixel = 0,
        LayoutOrder = self.Order,
        Size = UDim2.new(1, 0, 0, 40)
    }, {
        corner(4),
        stroke(self.Window.Accent, 1, 0.25)
    })
    row.Parent = self.Page
    self.Order += 1

    local label = new("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Position = UDim2.fromOffset(10, 0),
        Size = UDim2.new(0.5, -10, 1, 0),
        Text = labelText,
        TextColor3 = TEXT,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    label.Parent = row

    return row, label
end

function Tab:Toggle(labelText, default, callback)
    local row = self:_row(labelText)
    local enabled = default == true

    local box = new("TextButton", {
        AutoButtonColor = false,
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundColor3 = enabled and self.Window.Accent or Color3.fromRGB(22, 18, 26),
        BorderSizePixel = 0,
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.fromOffset(18, 18),
        Text = ""
    }, {
        corner(3),
        stroke(self.Window.Accent, 1, enabled and 1 or 0)
    })
    box.Parent = row

    local function set(value)
        enabled = value
        tween(box, 0.12, {
            BackgroundColor3 = enabled and self.Window.Accent or Color3.fromRGB(22, 18, 26)
        })

        if callback then
            task.spawn(callback, enabled)
        end
    end

    box.MouseButton1Click:Connect(function()
        set(not enabled)
    end)
    row.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            set(not enabled)
        end
    end)

    return {
        Set = set,
        Get = function()
            return enabled
        end
    }
end

function Tab:Slider(labelText, min, max, default, suffix, callback)
    min = min or 0
    max = max or 100
    default = math.clamp(default or min, min, max)
    suffix = suffix or ""

    local row = self:_row(labelText)
    local value = default

    local valueLabel = new("TextLabel", {
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Position = UDim2.new(1, -16, 0.5, 0),
        Size = UDim2.fromOffset(54, 18),
        Text = tostring(value) .. suffix,
        TextColor3 = TEXT,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right
    })
    valueLabel.Parent = row

    local track = new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundColor3 = Color3.fromRGB(35, 18, 33),
        BorderSizePixel = 0,
        Position = UDim2.new(1, -72, 0.5, 0),
        Size = UDim2.new(0, 188, 0, 8)
    }, {
        corner(2),
        stroke(self.Window.Accent, 1, 0.35)
    })
    track.Parent = row

    local fill = new("Frame", {
        BackgroundColor3 = self.Window.Accent,
        BorderSizePixel = 0,
        Size = UDim2.fromScale((value - min) / (max - min), 1)
    }, {
        corner(2)
    })
    fill.Parent = track

    local dragging = false

    local function setFromX(x)
        local percent = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local raw = min + (max - min) * percent
        value = math.floor(raw + 0.5)
        valueLabel.Text = tostring(value) .. suffix
        fill.Size = UDim2.fromScale(percent, 1)

        if callback then
            task.spawn(callback, value)
        end
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            setFromX(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            setFromX(input.Position.X)
        end
    end)

    return {
        Set = function(newValue)
            value = math.clamp(newValue, min, max)
            local percent = (value - min) / (max - min)
            valueLabel.Text = tostring(value) .. suffix
            fill.Size = UDim2.fromScale(percent, 1)
        end,
        Get = function()
            return value
        end
    }
end

function Tab:Bind(labelText, default, callback)
    local row = self:_row(labelText)
    local key = default or "None"
    local listening = false

    local button = new("TextButton", {
        AutoButtonColor = false,
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundColor3 = Color3.fromRGB(18, 16, 22),
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBold,
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.fromOffset(58, 24),
        Text = tostring(key),
        TextColor3 = TEXT,
        TextSize = 12
    }, {
        corner(3),
        stroke(self.Window.Accent, 1, 0.1)
    })
    button.Parent = row

    button.MouseButton1Click:Connect(function()
        listening = true
        button.Text = "..."
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then
            return
        end

        if listening then
            key = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode.Name or "None"
            listening = false
            button.Text = key

            if callback then
                task.spawn(callback, key)
            end
            return
        end

        if key ~= "None" and input.KeyCode.Name == key and callback then
            task.spawn(callback, key)
        end
    end)

    return {
        Set = function(newKey)
            key = newKey or "None"
            button.Text = key
        end,
        Get = function()
            return key
        end
    }
end

function Tab:Button(labelText, callback)
    local row = self:_row(labelText)

    local button = new("TextButton", {
        AutoButtonColor = false,
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundColor3 = self.Window.Accent,
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBold,
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.fromOffset(74, 24),
        Text = "Run",
        TextColor3 = Color3.fromRGB(15, 12, 18),
        TextSize = 12
    }, {
        corner(3)
    })
    button.Parent = row

    button.MouseButton1Click:Connect(function()
        if callback then
            task.spawn(callback)
        end
    end)
end

return setmetatable({}, Library)
