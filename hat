-- Rage Silent Aim + Auto Shoot (Mobile)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local Camera = workspace.CurrentCamera

local Settings = {
    Enabled = false,
    FOV = 360,              -- 360 = mira em qualquer lugar da tela
    AimPart = "Head",       -- Head ou HumanoidRootPart
    AutoShoot = true,       -- Atira automaticamente
    ShootDelay = 0.05,      -- Delay entre tiros (segundos)
    CheckVisible = false    -- true = só atira se ver o inimigo
}

-- Criar botão na tela
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = LocalPlayer.PlayerGui

local Button = Instance.new("TextButton")
Button.Size = UDim2.new(0, 80, 0, 80)
Button.Position = UDim2.new(0.83, 0, 0.83, 0)
Button.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
Button.Text = "🔥"
Button.TextSize = 35
Button.Font = Enum.Font.GothamBold
Button.Parent = ScreenGui

-- Variáveis de controle
local canShoot = true
local currentTarget = nil

-- Função pra pegar o inimigo mais próximo (qualquer lugar da tela)
local function GetClosestEnemy()
    local closest = nil
    local closestDist = Settings.FOV
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            
            local targetPart = player.Character:FindFirstChild(Settings.AimPart) or player.Character:FindFirstChild("HumanoidRootPart")
            if not targetPart then continue end
            
            local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
            if not onScreen then continue end
            
            -- Verifica se está visível (opcional)
            if Settings.CheckVisible then
                local ray = Ray.new(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * 1000)
                local hit = workspace:FindPartOnRay(ray, LocalPlayer.Character)
                if hit and hit:IsDescendantOf(player.Character) == false then
                    continue -- Inimigo atrás da parede
                end
            end
            
            local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
            
            if distance < closestDist then
                closestDist = distance
                closest = targetPart
            end
        end
    end
    
    return closest
end

-- Função pra atirar (simula clique sem bugar câmera)
local function Shoot()
    if not canShoot then return end
    if not Settings.Enabled then return end
    
    local target = GetClosestEnemy()
    if not target then return end
    
    currentTarget = target
    
    -- POSICIONA A MIRA NO ALVO (SILENT AIM)
    local targetPos = target.Position + Vector3.new(0, 0.5, 0)
    local fakeCFrame = CFrame.new(Mouse.Hit.Position, targetPos)
    
    -- Atualiza o mouse sem mexer na câmera
    Mouse.Target = target
    Mouse.Hit = fakeCFrame
    
    -- SIMULA O CLICK SEM BUGAR A CÂMERA
    -- Método 1: VirtualInputManager (mais suave)
    VirtualInputManager:SendMouseButtonEvent(
        Camera.ViewportSize.X / 2,  -- Centro da tela X
        Camera.ViewportSize.Y / 2,  -- Centro da tela Y
        0,                          -- Button (0 = esquerdo)
        true,                       -- Pressed (true = clicou)
        game,                       -- Objeto
        0                           -- UserID
    )
    
    -- Solta o clique depois de um tempo
    task.wait(0.01)
    VirtualInputManager:SendMouseButtonEvent(
        Camera.ViewportSize.X / 2,
        Camera.ViewportSize.Y / 2,
        0,
        false,
        game,
        0
    )
    
    -- Método 2 alternativo (se o 1 não funcionar, descomenta esse)
    -- mouse1click() -- Função nativa do Roblox
    
    -- Delay entre tiros
    canShoot = false
    task.wait(Settings.ShootDelay)
    canShoot = true
end

-- Loop principal - atira automaticamente
RunService.RenderStepped:Connect(function()
    if Settings.Enabled and Settings.AutoShoot then
        Shoot()
    end
end)

-- Toggle com o botão
Button.MouseButton1Click:Connect(function()
    Settings.Enabled = not Settings.Enabled
    Button.BackgroundColor3 = Settings.Enabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    Button.Text = Settings.Enabled and "✅" or "🔥"
    print("Rage Silent Aim: " .. tostring(Settings.Enabled))
end)

-- Ativar/Desativar com 3 toques na tela
local touchCount = 0
UserInputService.TouchStarted:Connect(function(touch, processed)
    if processed then return end
    
    touchCount = touchCount + 1
    
    if touchCount >= 3 then
        Settings.Enabled = not Settings.Enabled
        Button.BackgroundColor3 = Settings.Enabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
        Button.Text = Settings.Enabled and "✅" or "🔥"
        print("Rage Silent Aim: " .. tostring(Settings.Enabled))
        task.wait(0.5)
        touchCount = 0
    end
    
    task.wait(0.3)
    touchCount = 0
end)

-- Mostra o alvo atual na tela (opcional)
local function CreateESP()
    local esp = Instance.new("BillboardGui")
    esp.Size = UDim2.new(0, 100, 0, 30)
    esp.StudsOffset = Vector3.new(0, 2.5, 0)
    esp.Parent = LocalPlayer.Character
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "🎯"
    label.TextSize = 24
    label.TextColor3 = Color3.fromRGB(0, 255, 0)
    label.Parent = esp
    
    return esp
end

-- Cria ESP no personagem (opcional)
pcall(function()
    if not LocalPlayer.Character:FindFirstChild("AimESP") then
        CreateESP()
    end
end)

print("🔥 Rage Silent Aim carregado!")
print("Toque no botão ou 3 dedos na tela para ativar/desativar")
