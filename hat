local Players = game:GetService("Players")
local InsertService = game:GetService("InsertService")

local player = Players.LocalPlayer

-- CONFIG
local ACCESSORY_ID = 78605226794898
local ACCESSORY_COLOR = Color3.fromRGB(255, 0, 0) -- troca aqui
local ACCESSORY_MATERIAL = Enum.Material.ForceField -- troca aqui

local function applyVisualsToAccessory(accessory)
	for _, obj in ipairs(accessory:GetDescendants()) do
		if obj:IsA("BasePart") then
			obj.Material = ACCESSORY_MATERIAL
			obj.Color = ACCESSORY_COLOR
			obj.CanCollide = false
			obj.CastShadow = false
		end
	end
end

local function weldAccessoryToHead(character, accessory)
	local head = character:FindFirstChild("Head")
	if not head then return end

	local handle = accessory:FindFirstChild("Handle")
	if not handle or not handle:IsA("BasePart") then
		warn("Acessório sem Handle")
		return
	end

	accessory.Parent = character
	handle.Anchored = false
	handle.CanCollide = false

	-- remove welds antigos caso existam
	for _, v in ipairs(handle:GetChildren()) do
		if v:IsA("Weld") or v:IsA("WeldConstraint") or v:IsA("Motor6D") then
			v:Destroy()
		end
	end

	-- posiciona em cima da cabeça
	handle.CFrame = head.CFrame

	local weld = Instance.new("Weld")
	weld.Name = "AccessoryWeld"
	weld.Part0 = head
	weld.Part1 = handle
	weld.C0 = CFrame.new(0, 0.5, 0) -- ajusta altura aqui se precisar
	weld.Parent = head
end

local function equipAccessory()
	local character = player.Character or player.CharacterAdded:Wait()

	local success, model = pcall(function()
		return InsertService:LoadAsset(ACCESSORY_ID)
	end)

	if not success or not model then
		warn("Não foi possível carregar o acessório:", ACCESSORY_ID)
		return
	end

	local accessory = model:FindFirstChildWhichIsA("Accessory") or model:FindFirstChildWhichIsA("Hat")
	if not accessory then
		warn("Nenhum Accessory encontrado no asset")
		model:Destroy()
		return
	end

	accessory = accessory:Clone()
	model:Destroy()

	applyVisualsToAccessory(accessory)
	weldAccessoryToHead(character, accessory)
end

if player.Character then
	task.wait(1)
	equipAccessory()
end

player.CharacterAdded:Connect(function()
	task.wait(1)
	equipAccessory()
end)
