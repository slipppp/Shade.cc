-- Função para criar um chapéu simples de teste
local function createTestHat()
    print("🔄 Criando chapéu de teste...")
    
    -- Criar modelo
    local hatModel = Instance.new("Model")
    hatModel.Name = "TestHat"
    
    -- Base do chapéu
    local base = Instance.new("Part")
    base.Name = "Base"
    base.Size = Vector3.new(3.5, 0.3, 3.5)
    base.Shape = Enum.PartType.Cylinder
    base.BrickColor = BrickColor.new("Bright yellow")
    base.Material = Enum.Material.Wood
    base.CanCollide = false
    base.Anchored = false
    base.Parent = hatModel
    print("✅ Base criada")
    
    -- Topo do chapéu
    local top = Instance.new("Part")
    top.Name = "Top"
    top.Size = Vector3.new(2, 1.2, 2)
    top.Shape = Enum.PartType.Cylinder
    top.BrickColor = BrickColor.new("Bright yellow")
    top.Material = Enum.Material.Wood
    top.CanCollide = false
    top.Anchored = false
    top.Parent = hatModel
    print("✅ Topo criado")
    
    -- Fita vermelha
    local ribbon = Instance.new("Part")
    ribbon.Name = "Ribbon"
    ribbon.Size = Vector3.new(3.3, 0.15, 0.25)
    ribbon.BrickColor = BrickColor.new("Bright red")
    ribbon.Material = Enum.Material.Fabric
    ribbon.CanCollide = false
    ribbon.Anchored = false
    ribbon.Parent = hatModel
    print("✅ Fita criada")
    
    -- Posicionar na cabeça
    local headCFrame = head.CFrame
    local hatCFrame = headCFrame * CFrame.new(0, 1.3, 0)
    
    base.CFrame = hatCFrame * CFrame.new(0, -0.2, 0)
    top.CFrame = hatCFrame * CFrame.new(0, 0.8, 0)
    ribbon.CFrame = hatCFrame * CFrame.new(0, 0.1, 0)
    print("✅ Posições definidas")
    
    -- Conectar com weld
    local weld = Instance.new("Weld")
    weld.Part0 = head
    weld.Part1 = base
    weld.C0 = head.CFrame:Inverse() * hatCFrame
    weld.Parent = base
    print("✅ Weld criado")
    
    -- Adicionar ao personagem
    hatModel.Parent = character
    print("✅ Chapéu adicionado ao personagem")
    
    return hatModel
end

-- Função para tentar carregar o acessório pelo ID
local function loadAccessoryById(id)
    print("🔄 Tentando carregar acessório ID:", id)
    
    local success, result = pcall(function()
        return game:GetService("MarketplaceService"):LoadAsset(id)
    end)
    
    if success and result then
        print("✅ Acessório carregado com sucesso!")
        
        -- Tentar encontrar o modelo do chapéu
        local hatModel = result:FindFirstChildWhichIsA("Model") or result:FindFirstChildOfClass("Model")
        if hatModel then
            print("✅ Modelo encontrado:", hatModel.Name)
            
            -- Tentar encontrar o Handle
            local handle = hatModel:FindFirstChild("Handle") or hatModel:FindFirstChildWhichIsA("BasePart")
            if handle then
                print("✅ Handle encontrado:", handle.Name)
                
                -- Criar Accessory
                local accessory = Instance.new("Accessory")
                accessory.Name = "ChineseHat"
                accessory.Handle = handle
                accessory.Parent = character
                
                -- Posicionar na cabeça
                local head = character:FindFirstChild("Head")
                if head then
                    local weld = Instance.new("Weld")
                    weld.Part0 = head
                    weld.Part1 = handle
                    weld.C0 = CFrame.new(0, 1.2, 0)
                    weld.Parent = handle
                    print("✅ Acessório equipado com sucesso!")
                    return accessory
                else
                    print("❌ Cabeça não encontrada!")
                end
            else
                print("❌ Handle não encontrado no modelo!")
            end
        else
            print("❌ Modelo não encontrado no acessório!")
        end
    else
        print("❌ Erro ao carregar acessório:", result)
    end
    
    return nil
end

